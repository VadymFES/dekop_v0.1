{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, must-revalidate"
        }
      ]
    }
  ],
  "functions": {
    "app/api/webhooks/liqpay/route.ts": {
      "maxDuration": 30
    },
    "app/api/webhooks/monobank/route.ts": {
      "maxDuration": 30
    },
    "app/api/webhooks/resend/route.ts": {
      "maxDuration": 30
    },
    "app/api/orders/send-confirmation/route.ts": {
      "maxDuration": 30
    },
    "app/api/test/email/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/cleanup",
      "schedule": "0 2 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/((?!coming-soon|admin-path-57fyg|_next|api|sitemap\\.xml|sitemap|robots\\.txt|favicon\\.ico|.*\\..*).*)",
      "missing": [{ "type": "host", "value": "admin.dekop.com.ua" }],
      "destination": "/coming-soon",
      "permanent": false
    }
  ]
}